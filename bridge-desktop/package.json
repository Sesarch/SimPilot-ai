{
  "name": "simpilot-bridge-desktop",
  "version": "1.0.0",
  "description": "Tray-icon Electron wrapper around the SimPilot Bridge sidecar with a modern UI (status, telemetry, pairing token, start/stop).",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64 --publish never",
    "package:linux": "electron-packager . SimPilotBridge --platform=linux --arch=x64 --out=release --overwrite --prune=true --ignore=^/release",
    "package:win": "electron-packager . SimPilotBridge --platform=win32 --arch=x64 --out=release --overwrite --prune=true --ignore=^/release",
    "package:mac": "electron-packager . SimPilotBridge --platform=darwin --arch=x64 --out=release --overwrite --prune=true --ignore=^/release"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "@electron/packager": "^18.3.6",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.simpilot.bridge",
    "productName": "SimPilot Bridge",
    "copyright": "Copyright © 2025 SimPilot.AI",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../bridge",
        "to": "bridge-core",
        "filter": ["**/*", "!node_modules/**"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Sesarch SimPilot",
      "legalTrademarks": "SimPilot.AI",
      "artifactName": "SimPilotBridge-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SimPilot Bridge",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "menuCategory": "SimPilot",
      "uninstallDisplayName": "SimPilot Bridge ${version}",
      "installerIcon": "build/installerIcon.ico",
      "uninstallerIcon": "build/uninstallerIcon.ico",
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "artifactName": "SimPilotBridge-Setup-${version}.${ext}"
    }
  },
  "author": "SimPilot.AI",
  "license": "MIT"
}
