{
  "name": "simpilot-bridge-desktop",
  "version": "1.0.1",
  "description": "Tray-icon Electron wrapper around the SimPilot Bridge sidecar.",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.simpilot.bridge",
    "productName": "SimPilot Bridge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../bridge",
        "to": "bridge-core",
        "filter": ["**/*", "!node_modules/**"]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true
    }
  },
  "author": "SimPilot.AI",
  "license": "MIT"
}
